#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF'
tmux-dev-session - create/switch tmux sessions with feature-driven windows

Usage:
  tmux-dev-session <session_name> <project_path> [mode]

Modes:
  picker  Session layout used by dev/dev-worktree pickers (default)
  dev     Session layout used by dev-session
EOF
}

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
    usage >&2
    exit 1
fi

session_name="$1"
project_path="$2"
mode="${3:-picker}"

case "$mode" in
    picker|dev)
        ;;
    *)
        echo "Error: invalid mode '$mode' (expected 'picker' or 'dev')." >&2
        exit 1
        ;;
esac

if [ ! -d "$project_path" ]; then
    echo "Error: project path does not exist: $project_path" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/lib/tmux-session-lib.sh
. "$SCRIPT_DIR/lib/tmux-session-lib.sh"

tmux_require_config_tool
tmux_ensure_session "$session_name" "$project_path" "$mode"
