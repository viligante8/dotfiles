#!/usr/bin/env bash

set -euo pipefail

cat <<'EOF'
Development Tmux Shortcuts:

Project Sessions:
  dev                   - Use the tmux project picker (recommended)
  dev-worktree [path]   - Create/switch branch worktree from current repo
  dev-session [path]    - Start generic development session (default: current directory)

Utilities:
  dev-layout            - Create 3-pane development layout
  tmux-list             - List all active sessions
  tmux-attach [name]    - Attach/switch to session (most recent if omitted)
  tmux-clean            - Kill all tmux sessions
  tmux-help             - Show this help

Tmux Key Bindings (Prefix: M-space):
  M-space W             - Open project picker popup
  M-space B             - Create/switch branch worktree popup
  M-space V             - Quick editor drawer (configured command)
  M-space Q             - Quick AI drawer (configured command)
  M-space G             - Quick Git UI drawer (configured command)
  M-space D             - Quick 3-pane dev layout
  M-space c             - New window in current path
  M-space | / -         - Split horizontally / vertically
  M-space r             - Reload tmux config
  Alt-1 to Alt-9        - Switch windows 1-9
  Alt-arrows            - Switch panes
  Alt-q/e/w             - Prev session / next session / session picker
EOF
