#!/usr/bin/env bash

set -euo pipefail

if [ -z "${TMUX:-}" ]; then
    echo "Error: dev-layout must be run inside tmux." >&2
    exit 1
fi

current_path="$(tmux display-message -p "#{pane_current_path}")"
editor_pane="$(tmux display-message -p "#{pane_id}")"
terminal_top_pane="$(tmux split-window -h -c "$current_path" -P -F "#{pane_id}")"
terminal_bottom_pane="$(tmux split-window -v -t "$terminal_top_pane" -c "$current_path" -P -F "#{pane_id}")"

tmux select-pane -t "$editor_pane"
tmux send-keys "nvim" Enter

tmux select-pane -t "$terminal_top_pane"
tmux send-keys "clear" Enter

tmux select-pane -t "$terminal_bottom_pane"
tmux send-keys "clear" Enter

tmux select-pane -t "$editor_pane"
