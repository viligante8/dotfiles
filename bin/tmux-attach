#!/usr/bin/env bash

set -euo pipefail

usage() {
    echo "Usage: tmux-attach [session_name]" >&2
}

if [ $# -gt 1 ]; then
    usage
    exit 1
fi

if [ -n "${TMUX:-}" ]; then
    if [ $# -eq 0 ]; then
        tmux switch-client -l
    else
        tmux switch-client -t "$1"
    fi
    exit 0
fi

if [ $# -eq 0 ]; then
    tmux attach-session
else
    tmux attach-session -t "$1"
fi
